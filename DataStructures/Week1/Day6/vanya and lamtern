#include <bits/stdc++.h>
using namespace std;
int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    int n;
    long long l;
    cin >> n >> l;
    vector<long long> a(n);
    for (int i = 0; i < n; i++)
    {
        cin >> a[i];
    }

    sort(a.begin(), a.end());

    double ans = 0;

    ans = max(ans, (double)a[0]);
    ans = max(ans, (double)(l - a[n - 1]));

    for (int i = 0; i+1< n; i++)
    {
        ans = max(ans, (double)(a[i + 1] - a[i]) / 2.0);
    }

    cout << fixed << setprecision(10) << ans << endl;
    return 0;
}
